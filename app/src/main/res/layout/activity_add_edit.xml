<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="THÔNG TIN NHÂN VIÊN"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/aqua_primary"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <!-- Chọn loại dạng chip -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Loại nhân viên:"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <RadioGroup
            android:id="@+id/rgType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbStaff"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_radio_button"
                android:button="@null"
                android:gravity="center"
                android:text="Staff"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/rbManager"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_radio_button"
                android:button="@null"
                android:gravity="center"
                android:text="Manager"
                android:textColor="@color/text_primary" />

            <RadioButton
                android:id="@+id/rbIntern"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@drawable/bg_radio_button"
                android:button="@null"
                android:gravity="center"
                android:text="Intern"
                android:textColor="@color/text_primary" />
        </RadioGroup>

        <!-- Các trường nhập -->
        <EditText
            android:id="@+id/etMaNV"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Mã nhân viên"
            android:background="@drawable/bg_edittext"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etHoTen"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Họ tên"
            android:background="@drawable/bg_edittext"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etLuongCoBan"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Lương cơ bản (>0)"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_edittext"
            android:layout_marginBottom="8dp" />

        <!-- Trường thay đổi theo loại -->
        <TextView
            android:id="@+id/tvExtraLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số ngày công (0-26):"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etExtra"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Nhập giá trị"
            android:inputType="number"
            android:background="@drawable/bg_edittext"
            android:layout_marginBottom="12dp" />

        <!-- Nút Lưu & Hủy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Lưu"
                android:textColor="@color/white"
                android:background="@drawable/bg_button_aqua" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Hủy"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_outline"
                android:textColor="@color/aqua_primary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>